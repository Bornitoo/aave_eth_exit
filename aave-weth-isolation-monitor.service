[Unit]
Description=Aave Mantle WETH Isolation Monitor Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/aave-mantle-bot
EnvironmentFile=/root/aave-mantle-bot/settings.env
ExecStart=/usr/bin/python3 /root/aave-mantle-bot/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
