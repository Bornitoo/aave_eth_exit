[Unit]
Description=AAVE ETH EXIT Monitor Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/AAVE_ETH_EXIT
EnvironmentFile=/root/AAVE_ETH_EXIT/settings.env
ExecStart=/usr/bin/python3 /root/AAVE_ETH_EXIT/bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
